GEMINI_API_KEY=
# 1.5 系は 404、2.0-flash は無料枠で 429 になり得ます。まずは 2.5-flash を推奨。
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_MODEL=gemma3:4b

# Ollama: ホストで `python -m app.main` するときは 127.0.0.1（host.docker.internal はコンテナ向けでホストから解決できないことがあります）。
OLLAMA_BASE_URL=http://127.0.0.1:11434

# DB: ホスト直実行なら例: sqlite:///./data/agis.db  Docker 内は compose の DATABASE_URL が優先されます。
DATABASE_URL=sqlite:///./data/agis.db
