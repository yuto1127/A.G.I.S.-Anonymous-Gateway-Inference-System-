GEMINI_API_KEY=
# 1.5 系は 404、2.0-flash は無料枠で 429 になり得ます。まずは 2.5-flash を推奨。
GEMINI_MODEL=gemini-2.5-flash
# 匿名化ソース: auto（既定・業界連動Ollama）| both（+管理者ルール）| rules（非推奨）
# ollama は auto のエイリアス
MASKING_SOURCE=auto
# マスキング方式: abstract（既定・文意を保つ抽象化）| placeholder（[PERSON_1] 形式）
MASKING_MODE=abstract
# 業界（general | healthcare | finance | legal_hr）。GUI/CLI で上書き可
AGIS_INDUSTRY=general
# 抽象化ルール JSON（省略時は ./data/abstraction_rules.json）
# AGIS_ABSTRACTION_RULES_PATH=./data/abstraction_rules.json
# 秘匿ジャンル定義 JSON（省略時は ./data/masking_genres.json）
# MASKING_GENRES_PATH=./data/masking_genres.json
# 業界一覧・パック（省略時は ./data/industries.json と ./data/industry_packs/）
# AGIS_INDUSTRIES_PATH=./data/industries.json
# AGIS_INDUSTRY_PACKS_DIR=./data/industry_packs
# 操作ログ・CLI の既定 actor（未設定なら anonymous）
AGIS_ACTOR=
OLLAMA_MODEL=gemma3:4b

# Ollama: ホストで `python -m app.main` するときは 127.0.0.1（host.docker.internal はコンテナ向けでホストから解決できないことがあります）。
OLLAMA_BASE_URL=http://127.0.0.1:11434

# DB: ホスト直実行なら例: sqlite:///./data/agis.db  Docker 内は compose の DATABASE_URL が優先されます。
DATABASE_URL=sqlite:///./data/agis.db
